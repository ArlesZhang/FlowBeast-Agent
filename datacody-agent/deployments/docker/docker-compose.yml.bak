services:
  api:
    build: ../../.  # 关键：从子目录指向项目根目录的 . (当前目录)
    ports:
    command: uvicorn cody_agent.api.main:app --host 0.0.0.0 --port 8000
      - "8000:8000"
    env_file:
      - ../../.env  # 加载根目录 .env
    depends_on:
      - db
    restart: unless-stopped

  db:
    image: postgres:15
    environment:
      POSTGRES_USER: datacody
      POSTGRES_PASSWORD: secret
      POSTGRES_DB: datacody
    volumes:
      - postgres_data:/var/lib/postgresql/data
    restart: unless-stopped

volumes:
  postgres_data:
