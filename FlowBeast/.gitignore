# Python
__pycache__/
*.py[cod]
*.pyc
*.pyo
*.pyd
.pytest_cache/
*.egg-info/
dist/
build/
*.egg

# Environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# --- Data & Artifacts (FlowBeast 精确忽略) ---
test_data/
flowbeast/data/*.csv
flowbeast/data/*.parquet
flowbeast/data/*.json
# 彻底封锁数据文件夹但保留目录结构
flowbeast/data/*
!flowbeast/data/.gitkeep

# 忽略生成的代码中间产物
flowbeast/tmp/
generated_workflow.py

# Logs/Caches
logs/
*.log
*.cache
tmp/

# IDE/Editor
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Docker
*.dockerignore
Dockerfile.dev  # 如果有 dev 版

# Secrets
secrets/
api_keys.json

# Large files (用 Git LFS 或不 push)
*.zip
*.tar.gz
*.db  # 如 DuckDB 文件

# 忽略 market_material/raw_data 下的所有文件
flowbeast/market_material/raw_data/*

# 但不要忽略 .gitkeep 文件（前面的感叹号表示排除忽略）
!flowbeast/market_material/raw_data/.gitkeep
